{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": "./src",

    // Paths
    "paths": {
      "@lib/ws": ["lib/ws/WebSocketClient"],
      "@api": ["lib/api"],
      "@types-lib": ["lib/types/index"],
      "@types-lib/events": ["lib/ws/types"],
      "@store": ["store/store"],
      "@store/thunks/*": ["store/*"],
      "@pages/*": ["pages/*"],
      "@admin-pages/*": ["admin-pages/*"],
      "@assets/*": ["assets/*"],
      "@components/*": ["components/*"],
      "@hooks/*": ["hooks/*"]
    },

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
